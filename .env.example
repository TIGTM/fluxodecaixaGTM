# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3400
NODE_ENV=production

# Use uma chave forte e unica em producao
SESSION_SECRET=troque-por-uma-chave-longa-e-segura
SESSION_TTL_MS=28800000

# ── Regras de autenticacao local ───────────────────────────────────────────
AUTH_MIN_PASSWORD_LENGTH=8
AUTH_REQUIRE_STRONG_PASSWORD=true

# Se true, so permite cadastro de CPF presente na whitelist
AUTH_REQUIRE_CPF_ALLOWLIST=true

# Opcao 1: whitelist por variavel de ambiente (separe por virgula)
# Exemplo: AUTH_ALLOWED_CPFS=12345678909,98765432100
AUTH_ALLOWED_CPFS=

# Opcao 2: whitelist por arquivo JSON local
# Caminho padrao: .data/allowed-cpfs.json
# AUTH_ALLOWED_CPFS_FILE=.data/allowed-cpfs.json

# ── Credenciais OAuth 2.0 Sankhya (exemplo) ───────────────────────────────
SANKHYA_CLIENT_ID=seu-client-id
SANKHYA_CLIENT_SECRET=seu-client-secret
SANKHYA_APPKEY=sua-app-key
